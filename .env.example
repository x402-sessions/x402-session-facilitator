# x402-sessions facilitator configuration

# HTTP server
PORT=4021

# Stellar network
STELLAR_NETWORK=stellar:testnet
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Facilitator signing key (this account pays fees and is the `spender` in SAC approve/transfer_from).
# Must be funded with testnet XLM. Generate with: stellar keys generate --fund --network testnet
FACILITATOR_SECRET=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# USDC SAC contract id on testnet
USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# Decimals for the asset (USDC on Stellar = 7)
ASSET_DECIMALS=7

# Max per-call price in decimal units (policy limit; /settle refuses amounts above this)
MAX_PER_CALL=1.00

# SQLite path
DB_PATH=./sessions.db
